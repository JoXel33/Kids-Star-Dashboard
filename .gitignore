# Microsoft Office temp / lock files
~$*
~WRL*.tmp
*.tmp

# Node.js
node_modules/

# Claude Code local settings (user/machine-specific — shared settings.json is tracked)
.claude/settings.local.json

# Environment / secrets
.env

# SQLite database files
backend/data/

# Playwright runtime artifacts
test-results/
playwright-report/
playwright/.cache/

# OS files
.DS_Store
Thumbs.db

